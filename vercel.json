{
  "functions": {
    "api/**/*.ts": {
      "includeFiles": ["background.*", "public/background.*"]
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/download/(.*)", "destination": "/api/index" },
    { "source": "/local-bg/(.*)", "destination": "/api/index" },
    { "source": "/preview/(.*)", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
