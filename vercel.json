{
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "background.*"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/download/(.*)", "destination": "/api" },
    { "source": "/local-bg/(.*)", "destination": "/api" },
    { "source": "/preview/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
